rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Single iOS write at trip completion: FirebaseService.writeTripCompletionToFirebase (PATCH = create-or-merge).
    // RN should use the same field set. Not incremental per-point updates.
    function mobileTripWriteKeys() {
      return [
        'tripId', 'destinationCode', 'timezonesCount', 'travelDirection',
        'pointsCompleted', 'startDate', 'completionDate', 'completionMethod',
        'point1Completed', 'point2Completed', 'point3Completed',
        'point4Completed', 'point5Completed', 'point6Completed',
        'point7Completed', 'point8Completed', 'point9Completed',
        'point10Completed', 'point11Completed', 'point12Completed',
        'surveyCompleted', 'arrivalTimeZone', 'originTimezone', 'originTimeZone',
        'useCrampedPoints', 'surveyCode', 'deviceId'
      ];
    }

    // survey.html initial submit (incl. fallback that may add tripId / surveyCode / created).
    function surveySubmissionKeys() {
      return [
        'surveyCompleted', 'surveySubmittedAt',
        'userComment', 'ageRange',
        'generalAnticipated', 'sleepPost', 'fatiguePost', 'concentrationPost',
        'irritabilityPost', 'motivationPost', 'giPost',
        'tripId', 'surveyCode', 'created'
      ];
    }

    // Post-completion survey edits: survey answers only (no trip metadata rewrites).
    function surveyEditKeys() {
      return [
        'surveyCompleted', 'surveySubmittedAt',
        'userComment', 'ageRange',
        'generalAnticipated', 'sleepPost', 'fatiguePost', 'concentrationPost',
        'irritabilityPost', 'motivationPost', 'giPost'
      ];
    }

    // Initial survey submit: if tripId is written, it must match the document id.
    function surveySubmitShapeOk(tid) {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(surveySubmissionKeys())
        && (!affected.hasAny(['tripId']) || request.resource.data.tripId == tid);
    }

    // Post-completion survey edits: only answer fields.
    function surveyEditShapeOk() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(surveyEditKeys());
    }

    // One mobile full write while survey open; after that only survey fields (submit or edit answers).
    function tripCompletionUpdateAllowed(tid) {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let surveyNotDone = resource.data.surveyCompleted != true;
      return (surveyNotDone && affected.hasOnly(mobileTripWriteKeys()))
        || (surveyNotDone
            && request.resource.data.surveyCompleted == true
            && surveySubmitShapeOk(tid))
        || (resource.data.surveyCompleted == true && surveyEditShapeOk());
    }

    // New docs: HMAC-signed 5-part id (AppState / HMACGenerator). Legacy reads unchanged.
    function signedTripIdCreate(tid) {
      return request.resource.data.tripId == tid
        && tid.matches('^[A-F0-9]{8}-[A-Z]{4}-[0-9]{6}-[0-9]{4}-[a-f0-9]{8}$');
    }

    match /tripCompletions/{tripId} {
      allow read: if true;
      allow create: if signedTripIdCreate(tripId);
      allow update: if tripCompletionUpdateAllowed(tripId);
      allow delete: if false;
    }

    match /tripCompletionsDev/{tripId} {
      allow read: if true;
      allow create: if signedTripIdCreate(tripId);
      allow update: if tripCompletionUpdateAllowed(tripId);
      allow delete: if false;
    }

    match /auditLog/{entry} {
      allow read: if true;
      allow write: if false;
    }

    match /_system/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /_snapshots/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}
